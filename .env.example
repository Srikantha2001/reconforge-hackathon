# ============================================================================
# ReconForge — centralized configuration (copy to .env and adjust)
# ============================================================================

# --- Database -------------------------------------------------------------
# Local run uses the Postgres started by docker-compose.
POSTGRES_USER=reconforge
POSTGRES_PASSWORD=reconforge
POSTGRES_DB=reconforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full SQLAlchemy URL. If set, it overrides the POSTGRES_* parts above.
# For tests you may point this at SQLite, e.g. sqlite+pysqlite:///./data/test.db
DATABASE_URL=postgresql+psycopg2://reconforge:reconforge@localhost:5432/reconforge

# --- LLM provider (pluggable) --------------------------------------------
# Provider selects which adapter authors config + runs the SME/Judge agents.
#   stub    -> deterministic, no API key needed (default; fully offline)
#   gemini  -> Google Gemini (needs GEMINI_API_KEY)
#   openai  -> OpenAI-compatible endpoint (needs OPENAI_API_KEY [+ OPENAI_BASE_URL])
LLM_PROVIDER=stub
LLM_MODEL=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- App ------------------------------------------------------------------
# Autonomy dial: Judge confidence >= threshold auto-accepts; below routes to human.
STP_THRESHOLD=0.90
# Where uploaded CSVs are stored (path stored in the `run` table).
UPLOAD_DIR=./uploads
# CORS origin for the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173
