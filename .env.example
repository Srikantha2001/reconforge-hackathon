# ============================================================================
# ReconForge / ReconOS — centralized configuration (copy to .env and adjust)
# ============================================================================

# --- Database -------------------------------------------------------------
# SQLite is the default and only supported database (Postgres was removed
# 2026-07-22 by user decision). The path is relative to the backend working
# directory: on the host that is backend/data/reconforge.db; inside the
# Docker container it resolves to /app/data/reconforge.db.
DATABASE_URL=sqlite+pysqlite:///./data/reconforge.db

# --- LLM provider (pluggable) --------------------------------------------
# Provider selects which adapter authors config + runs the SME/Judge agents.
#   stub    -> deterministic, no API key needed (default; fully offline)
#   gemini  -> Google Gemini (needs GEMINI_API_KEY)
#   openai  -> OpenAI-compatible endpoint (needs OPENAI_API_KEY [+ OPENAI_BASE_URL])
LLM_PROVIDER=stub
LLM_MODEL=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- App ------------------------------------------------------------------
# Autonomy dial: Judge confidence >= threshold auto-accepts; below routes to human.
STP_THRESHOLD=0.90
# Where uploaded CSVs are stored (path stored in the `run` table).
UPLOAD_DIR=./uploads
# CORS origin for the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173

# --- Auth (JWT — used from P4 on) ------------------------------------------
SECRET_KEY=reconos-hackathon-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# --- Governance thresholds (EUR) -------------------------------------------
WRITE_OFF_AUTO_APPROVE_BELOW=500.00
WRITE_OFF_DUAL_CHECKER_ABOVE=10000.00
PENDING_APPROVAL_EXPIRY_HOURS=24

# --- Regulatory thresholds --------------------------------------------------
EMIR_AMOUNT_THRESHOLD_EUR=15000000.00
EMIR_DAYS_THRESHOLD=15
CASS_SHORTFALL_THRESHOLD_EUR=1000.00

# --- Subset-sum matcher performance guards ----------------------------------
SUBSET_SUM_MAX_GROUP_SIZE=4
SUBSET_SUM_MAX_ROWS_PER_PARTITION=50
SUBSET_SUM_TIMEOUT_SECONDS=30
